{
  "name": "7even",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/mobile",
    "apps/worker"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run start:dev",
    "dev:worker": "npm --workspace apps/worker run start:dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "build": "npm run build:api && npm run build:worker && npm run build:mobile",
    "build:api": "npm --workspace apps/api run build",
    "build:worker": "npm --workspace apps/worker run build",
    "build:mobile": "npm --workspace apps/mobile run build",
    "test": "npm --workspace apps/api run test"
  }
}
